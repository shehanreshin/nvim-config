{
  "palette": {
    "crust": "#050A0D",
    "mantle": "#0A1217",
    "base": "#101A20",
    "surface0": "#1C2C31",
    "surface1": "#273A3D",
    "surface2": "#364C4D",
    "overlay0": "#4A6161",
    "overlay1": "#617776",
    "overlay2": "#7A9190",
    "subtext0": "#91A8A4",
    "subtext1": "#B5C9C4",
    "text": "#D6E7E2",
    "rosewater": "#DDF7EE",
    "flamingo": "#B7E9D7",
    "pink": "#9DE3D2",
    "lavender": "#8FA8D6",
    "blue": "#63B7D8",
    "sky": "#58C7D9",
    "teal": "#35B8AC",
    "green": "#4FBE93",
    "yellow": "#CDBE74",
    "peach": "#D89A6A",
    "red": "#D86478",
    "maroon": "#B94A5B",
    "mauve": "#7E97C2",
    "sapphire": "#48AFCF",
    "os": "p:subtext1",
    "session": "p:sky",
    "path": "p:text",
    "path_icon": "p:teal",
    "git": "p:green",
    "closer": "p:overlay1"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:os",
          "style": "plain",
          "template": "{{ .Icon }} ",
          "type": "os"
        },
        {
          "foreground": "p:session",
          "style": "plain",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "foreground": "p:path",
          "options": {
            "folder_icon": "..\ue5fe..",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "p:git",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "style": "plain",
          "template": "{{ .HEAD }} ",
          "type": "git"
        },
        {
          "foreground": "p:closer",
          "style": "plain",
          "template": "\uf105",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 1
}
